# ============================================================
# FoodLoop Production Environment Variables Template
# Copy this file to '.env' and fill in your production settings.
# ============================================================

# --- Database Credentials ---
DB_HOST=localhost
DB_NAME=foodloop_db
DB_USER=root
DB_PASS=""
DB_PORT=3306

# Alternatively, use a single DATABASE_URL (uncomment to use):
# DATABASE_URL=mysql://root:password@localhost:3306/foodloop_db

# --- SMTP Mailer Settings ---
# Set to 'true' to send real emails via SMTP. Set to 'false' to log emails to emails.log locally.
USE_SMTP=false

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com
SMTP_FROM_NAME="FoodLoop Admin"
